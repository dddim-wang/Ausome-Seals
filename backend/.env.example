CONTACT_TO_EMAIL=support@ausomeseals.com

# Recommended for Railway: Resend uses HTTPS instead of SMTP ports.
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=Ausome Seals <onboarding@resend.dev>

# Optional SMTP fallback for hosts that allow outbound SMTP.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_USERNAME=your-sender@gmail.com
# SMTP_PASSWORD=your-gmail-app-password
# SMTP_FROM_EMAIL=your-sender@gmail.com

# Optional: lock API access to the deployed frontend domain.
FRONTEND_ORIGIN=http://localhost:5173

# Contact form protection. Use Redis storage when running multiple backend instances.
MAX_API_REQUEST_BYTES=32768
RATELIMIT_STORAGE_URI=memory://

# AI chat provider. Use stub for offline development or deepseek in production.
AI_PROVIDER=stub
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_THINKING_ENABLED=false

# Local PDF RAG. The service searches backend/knowledge, project/knowledge,
# then backend/tests/knowledge. The index cache is rebuilt when PDFs change.
RAG_ENABLED=true
RAG_KNOWLEDGE_DIR=knowledge
RAG_RESULT_LIMIT=5
